int main() {
    judul("SISTEM PENDATAAN TURNAMEN ESPORT");
    cout << "  Program UAS - Pemrograman Berorientasi Objek\n";
    cout << "  Universitas Tadulako 2025\n";
    garis();

    // Setup turnamen
    string nama_t, lokasi_t, tanggal_t, sponsor_t;
    long long h1, h2, h3;
    int kat;

    cout << "\n  === Setup Turnamen ===\n";
    cout << "  Nama Turnamen  : "; getline(cin, nama_t);
    cout << "  Lokasi         : "; getline(cin, lokasi_t);
    cout << "  Tanggal        : "; getline(cin, tanggal_t);
    cout << "  Sponsor Utama  : "; getline(cin, sponsor_t);

    // Pilih kategori game turnamen
    cout << "  Kategori Game  :\n";
    cout << "    1. MOBA\n";
    cout << "    2. FPS\n";
    cout << "    3. Battle Royale\n";
    cout << "  Pilihan        : "; cin >> kat; clearBuffer();

    string kategori;
    if      (kat == 1) kategori = "MOBA";
    else if (kat == 2) kategori = "FPS";
    else               kategori = "Battle Royale";

    cout << "  Hadiah Juara 1 : Rp "; cin >> h1; clearBuffer();
    cout << "  Hadiah Juara 2 : Rp "; cin >> h2; clearBuffer();
    cout << "  Hadiah Juara 3 : Rp "; cin >> h3; clearBuffer();

    Hadiah   hadiah(h1, h2, h3, sponsor_t);
    Turnamen turnamen(nama_t, lokasi_t, tanggal_t, kategori, &hadiah);

    cout << "\n  Turnamen \"" << nama_t << "\" kategori "
         << kategori << " berhasil dibuat!\n";
    cout << "  Hanya tim " << kategori
         << " yang dapat didaftarkan.\n";

    // =========================================================
    //  DATA DEFAULT (untuk kemudahan demo presentasi)
    //  Semua tim sejenis dengan kategori turnamen
    // =========================================================
    // Karena kategori dipilih user, data default dibuat dinamis
    Tim* d1 = nullptr;
    Tim* d2 = nullptr;
    Tim* d3 = nullptr;

    if (kategori == "MOBA") {
        d1 = new TimMOBA("Legends of Tadulako", "Palu",     "LOT");
        d2 = new TimMOBA("Storm Riders",         "Donggala", "STR");
        d3 = new TimMOBA("Ragnarok Crew",         "Parigi",   "RGC");
    } else if (kategori == "FPS") {
        d1 = new TimFPS("Alpha Squad",   "Palu",     "ALS");
        d2 = new TimFPS("FPS Warriors",  "Donggala", "FPSW");
        d3 = new TimFPS("Shadow Force",  "Parigi",   "SHF");
    } else {
        d1 = new TimBattleRoyale("Drop Zone",     "Palu",     "DRZ");
        d2 = new TimBattleRoyale("Last Breath",   "Donggala", "LBR");
        d3 = new TimBattleRoyale("Survival Kings","Parigi",   "SVK");
    }

    // Tambah roster anggota
    d1->tambahAnggota("Adit"); d1->tambahAnggota("Bima");
    d1->tambahAnggota("Caca"); d1->tambahAnggota("Doni");

    d2->tambahAnggota("Eka");  d2->tambahAnggota("Fajar");
    d2->tambahAnggota("Gus");  d2->tambahAnggota("Hilda");

    d3->tambahAnggota("Intan"); d3->tambahAnggota("Joko");
    d3->tambahAnggota("Kiki");  d3->tambahAnggota("Lana");

    // Daftarkan ke turnamen (akan otomatis divalidasi)
    turnamen.daftarkanTim(d1);
    turnamen.daftarkanTim(d2);
    turnamen.daftarkanTim(d3);
    // =========================================================

    int pilihan = -1;
    do {
        garis();
        cout << "  MENU UTAMA - " << turnamen.getNama()
             << " [" << turnamen.getKategoriGame() << "]\n";
        garis();
        cout << "  [DATA TIM]\n";
        cout << "   1. Daftarkan Tim Baru\n";
        cout << "   2. Lihat Daftar Tim\n";
        cout << "   3. Lihat Detail Tim\n";
        cout << "   4. Edit Data Tim\n";
        cout << "   5. Hapus Tim\n";
        cout << "   6. Kelola Anggota Tim\n";
        cout << "  [PERTANDINGAN]\n";
        cout << "   7. Buat Jadwal Otomatis\n";
        cout << "   8. Lihat Jadwal\n";
        cout << "   9. Input Hasil Pertandingan\n";
        cout << "  [LAPORAN]\n";
        cout << "  10. Lihat Klasemen & Juara\n";
        cout << "  11. Lihat Info Turnamen\n";
        cout << "  12. Reset Semua Statistik\n";
        cout << "   0. Keluar\n";
        garis();
        cout << "  Pilihan: ";

        while (!(cin >> pilihan)) {
            cin.clear();
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            cout << "  Input tidak valid! Masukkan angka: ";
        }
        clearBuffer();

        switch (pilihan) {
            case 1: {
                cout << "\n--- Daftarkan Tim Baru ---\n";
                cout << "  Catatan: turnamen ini khusus tim "
                     << turnamen.getKategoriGame() << "!\n";
                int jumlah_sebelum = turnamen.jumlahTim();
                Tim* t = inputTimBaru();
                turnamen.daftarkanTim(t);
                // Jika tim ditolak (beda kategori/duplikat), hapus agar tidak memory leak
                if (turnamen.jumlahTim() == jumlah_sebelum) {
                    delete t;
                }
                break;
            }
            case 2:  turnamen.tampilDaftarTim();     break;
            case 3:  turnamen.tampilDetailTim();     break;
            case 4:  turnamen.editTim();             break;
            case 5:  turnamen.hapusTim();            break;
            case 6:  turnamen.kelolaAnggota();       break;
            case 7:  turnamen.buatJadwal();          break;
            case 8:  turnamen.tampilJadwal();        break;
            case 9:  turnamen.inputHasil();          break;
            case 10: turnamen.tampilKlasemen();      break;
            case 11: turnamen.tampilInfoTurnamen();  break;
            case 12: turnamen.resetSemuaStatistik(); break;
            case 0:
                cout << "\n  Terima kasih! Data turnamen selesai dicatat.\n";
                break;
            default:
                cout << "  Pilihan tidak valid!\n";
        }
    } while (pilihan != 0);

    return 0;
}
