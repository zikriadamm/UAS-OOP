// ============================================================
//  HELPER
// ============================================================
void clearBuffer() {
    cin.ignore(numeric_limits<streamsize>::max(), '\n');
}

void garis(char c = '=', int n = 55) {
    for (int i = 0; i < n; i++) cout << c;
    cout << endl;
}

void judul(string teks) {
    garis();
    cout << "  " << teks << endl;
    garis();
}

// ============================================================
//  MODUL 4 - ABSTRACT CLASS
// ============================================================
class Peserta {
protected:
    string nama;
    string asal_kota;

public:
    Peserta(string n, string a) : nama(n), asal_kota(a) {}

    // Pure virtual function -> Peserta adalah abstract class
    virtual void tampilInfo()          = 0;
    virtual void tampilInfo(bool ringkas) = 0;
    virtual string getTipe()           = 0;
    virtual string getKategoriGame()   = 0; // <-- BARU: tiap subclass wajib override

    // MODUL 2 - Getter & Setter (Encapsulation)
    string getNama()     { return nama; }
    string getAsalKota() { return asal_kota; }

    void setNama(string n) {
        if (n.empty()) { cout << "  Nama tidak boleh kosong!\n"; return; }
        nama = n;
    }
    void setAsalKota(string a) {
        if (a.empty()) { cout << "  Asal kota tidak boleh kosong!\n"; return; }
        asal_kota = a;
    }

    virtual ~Peserta() {}
};

// ============================================================
//  MODUL 1, 2 - BASE CLASS Tim
// ============================================================
class Tim : public Peserta {
protected:
    string         nama_game;
    string         tag_tim;
    vector<string> anggota;
    int            menang;
    int            kalah;
    int            poin;

public:
    // MODUL 2 - Constructor tanpa parameter
    Tim() : Peserta("Unknown", "Unknown"),
            nama_game("-"), tag_tim("-"),
            menang(0), kalah(0), poin(0) {}

    // MODUL 2 - Constructor dengan parameter
    Tim(string n, string a, string game, string tag)
        : Peserta(n, a), nama_game(game), tag_tim(tag),
          menang(0), kalah(0), poin(0) {}

    // MODUL 2 - Constructor overloading: tanpa tag
    Tim(string n, string a, string game)
        : Peserta(n, a), nama_game(game), tag_tim("???"),
          menang(0), kalah(0), poin(0) {}

    // MODUL 2 - Getter & Setter (Encapsulation)
    string getNamaGame()   { return nama_game; }
    string getTag()        { return tag_tim; }
    int    getMenang()     { return menang; }
    int    getKalah()      { return kalah; }
    int    getPoin()       { return poin; }
    int    jumlahAnggota() { return (int)anggota.size(); }
    vector<string>& getAnggota() { return anggota; }

    void setTag(string t) {
        if (t.empty()) { cout << "  Tag tidak boleh kosong!\n"; return; }
        tag_tim = t;
    }
    void setPoin(int p) {
        if (p < 0) { cout << "  Poin tidak boleh negatif!\n"; return; }
        poin = p;
    }

    void tambahAnggota(string nama_pemain) {
        if (nama_pemain.empty()) { cout << "  Nama pemain tidak boleh kosong!\n"; return; }
        for (auto& a : anggota) {
            if (a == nama_pemain) {
                cout << "  Pemain \"" << nama_pemain << "\" sudah ada di tim!\n";
                return;
            }
        }
        anggota.push_back(nama_pemain);
        cout << "  Pemain \"" << nama_pemain
             << "\" ditambahkan ke " << nama << "!\n";
    }

    void hapusAnggota(int index) {
        if (index < 0 || index >= (int)anggota.size()) {
            cout << "  Index tidak valid!\n"; return;
        }
        cout << "  Pemain \"" << anggota[index]
             << "\" dihapus dari " << nama << "!\n";
        anggota.erase(anggota.begin() + index);
    }

    void catatMenang() { menang++; poin += 3; }
    void catatKalah()  { kalah++;             }
    void catatSeri()   { poin += 1;           }

    void resetStatistik() {
        menang = 0; kalah = 0; poin = 0;
        cout << "  Statistik " << nama << " direset!\n";
    }

    // MODUL 2 - Method return value
    string getStatus() {
        if (menang == 0 && kalah == 0) return "Belum main";
        if (menang > kalah)  return "Lolos";
        if (menang == kalah) return "Imbang";
        return "Tersingkir";
    }

    // MODUL 2 - Method tanpa parameter & return value
    void cetakRoster() {
        cout << "  Roster " << nama << " [" << tag_tim << "]:\n";
        if (anggota.empty()) { cout << "    (belum ada anggota)\n"; return; }
        for (int i = 0; i < (int)anggota.size(); i++)
            cout << "    " << (i+1) << ". " << anggota[i] << "\n";
    }

    // MODUL 4 - Override pure virtual
    string getTipe() override { return "Tim"; }

    // wajib diimplementasi subclass (pure virtual dari Peserta)
    string getKategoriGame() override { return nama_game; }

    // MODUL 2 - Method overloading (2 versi)
    void tampilInfo() override {
        garis('-', 55);
        cout << "  Nama Tim   : " << nama      << " [" << tag_tim << "]\n";
        cout << "  Asal Kota  : " << asal_kota << "\n";
        cout << "  Game       : " << nama_game << "\n";
        cout << "  Tipe       : " << getTipe() << "\n";
        cout << "  Anggota    : ";
        if (anggota.empty()) cout << "(belum ada)";
        for (int i = 0; i < (int)anggota.size(); i++) {
            if (i > 0) cout << ", ";
            cout << anggota[i];
        }
        cout << "\n";
        cout << "  Statistik  : " << menang << "M / "
             << kalah << "K | Poin: " << poin << "\n";
        cout << "  Status     : " << getStatus() << "\n";
        garis('-', 55);
    }

    void tampilInfo(bool ringkas) override {
        if (ringkas) {
            cout << "  [" << left << setw(5) << tag_tim << "] "
                 << setw(22) << nama
                 << setw(15) << asal_kota
                 << getTipe() << "\n";
        } else {
            tampilInfo();
        }
    }
};

// ============================================================
//  MODUL 3 - SUBCLASS (Inheritance + Scope Resolution)
// ============================================================
class TimMOBA : public Tim {
private:
    int kuota_pemain;

public:
    // MODUL 3 - Base Class Constructor via initializer list
    TimMOBA(string n, string a, string tag)
        : Tim(n, a, "MOBA", tag), kuota_pemain(5) {}

    string getTipe()         override { return "Tim MOBA"; }
    string getKategoriGame() override { return "MOBA"; }

    // MODUL 4 - Method Overriding
    void tampilInfo() override {
        Tim::tampilInfo(); // MODUL 3 - Scope Resolution Operator
        cout << "  [MOBA] Kuota : " << kuota_pemain << " pemain"
             << " | Terisi: " << jumlahAnggota()
             << "/" << kuota_pemain << "\n";
        garis('-', 55);
    }

    void tampilInfo(bool ringkas) override {
        if (ringkas) Tim::tampilInfo(true);
        else tampilInfo();
    }
};

