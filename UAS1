        string reg;
        cout << "  Region     : "; getline(cin, reg);
        if (reg.empty()) reg = "Asia";
        return new TimHoK(nama, asal, tag, reg);
    } else { // Dota 2
        cout << "  Divisi     :\n";
        cout << "    1. Open\n";
        cout << "    2. Challengers\n";
        cout << "    3. Premier\n";
        int d;
        do {
            cout << "  Pilihan (1-3): ";
            while (!(cin >> d)) { cin.clear(); clearBuffer(); cout << "  Input angka: "; }
            clearBuffer();
            if (d < 1 || d > 3) cout << "  Pilihan harus 1-3!\n";
        } while (d < 1 || d > 3);
        string divisi = (d == 1) ? "Open" : (d == 2) ? "Challengers" : "Premier";
        return new TimDota(nama, asal, tag, divisi);
    }
}
 
