class Hadiah {
private:
    long long juara1;
    long long juara2;
    long long juara3;
    string    sponsor;
 
public:
    Hadiah(long long h1, long long h2, long long h3, string sp)
        : juara1(h1), juara2(h2), juara3(h3), sponsor(sp) {}
 
    long long getHadiah(int juara) const {
        if (juara == 1) return juara1;
        if (juara == 2) return juara2;
        if (juara == 3) return juara3;
        return 0;
    }
    string getSponsor() const { return sponsor; }
 
    void tampilHadiah() {
        garis('*', 55);
        cout << "  PRIZE POOL | Sponsor: " << sponsor << "\n";
        garis('*', 55);
        cout << "  Juara 1 : Rp " << juara1 << "\n";
        cout << "  Juara 2 : Rp " << juara2 << "\n";
        cout << "  Juara 3 : Rp " << juara3 << "\n";
        garis('*', 55);
    }
};
 
// ============================================================
//  MODUL 1 - CLASS Pertandingan
// ============================================================
class Pertandingan {
private:
    int  nomor;
    Tim* tim1;
    Tim* tim2;
    int  skor1;
    int  skor2;
    bool selesai;
 
public:
    Pertandingan(int no, Tim* t1, Tim* t2)
        : nomor(no), tim1(t1), tim2(t2),
          skor1(0), skor2(0), selesai(false) {}
 
    void inputSkor() {
        if (selesai) { cout << "  Pertandingan ini sudah selesai!\n"; return; }
        garis('-', 55);
        cout << "  Match " << nomor << " : "
             << tim1->getNama() << " vs " << tim2->getNama() << "\n";
        garis('-', 55);
 
        do {
            cout << "  Skor " << tim1->getNama() << " : ";
            while (!(cin >> skor1)) {
                cin.clear(); clearBuffer();
                cout << "  Input tidak valid! Masukkan angka: ";
            }
            if (skor1 < 0) cout << "  Skor tidak boleh negatif!\n";
        } while (skor1 < 0);
 
        do {
            cout << "  Skor " << tim2->getNama() << " : ";
            while (!(cin >> skor2)) {
                cin.clear(); clearBuffer();
                cout << "  Input tidak valid! Masukkan angka: ";
            }
            if (skor2 < 0) cout << "  Skor tidak boleh negatif!\n";
        } while (skor2 < 0);
 
        clearBuffer();
 
        cout << "\n  HASIL: ";
        if (skor1 > skor2) {
            tim1->catatMenang(); tim2->catatKalah();
            cout << tim1->getNama() << " MENANG! ("
                 << skor1 << "-" << skor2 << ")\n";
        } else if (skor2 > skor1) {
            tim2->catatMenang(); tim1->catatKalah();
            cout << tim2->getNama() << " MENANG! ("
                 << skor2 << "-" << skor1 << ")\n";
        } else {
            tim1->catatSeri(); tim2->catatSeri();
            cout << "SERI! (" << skor1 << "-" << skor2 << ")\n";
        }
        selesai = true;
    }
 
    void tampilBaris() {
        cout << "  Match " << setw(2) << nomor << " : "
             << left << setw(22) << tim1->getNama()
             << "vs " << setw(22) << tim2->getNama();
        if (selesai) cout << "| " << skor1 << " - " << skor2;
        else         cout << "| Belum dimainkan";
        cout << "\n";
    }
 
    bool getSudahSelesai() const { return selesai; }
    int  getNomor()        const { return nomor;   }
};
 
// ============================================================
//  MODUL 1 - CLASS Turnamen (khusus MOBA)
// ============================================================
class Turnamen {
private:
    string               nama;
    string               lokasi;
    string               tanggal;
    string               game_moba;   // game MOBA spesifik turnamen ini
    vector<Tim*>         daftar_tim;
    vector<Pertandingan> jadwal;
    Hadiah*              hadiah;
 
public:
    Turnamen(string n, string lok, string tgl, string game, Hadiah* h)
        : nama(n), lokasi(lok), tanggal(tgl), game_moba(game), hadiah(h) {}
 
    bool daftarkanTim(Tim* t) {
        if (t->getKategoriGame() != game_moba) {
            cout << "  GAGAL! Tim \"" << t->getNama() << "\""
                 << " adalah tim " << t->getKategoriGame()
                 << ", sedangkan turnamen ini khusus " << game_moba << "!\n";
            return false;
        }
        for (auto tim : daftar_tim) {
            if (tim->getNama() == t->getNama()) {
                cout << "  GAGAL! Tim \"" << t->getNama()
                     << "\" sudah terdaftar!\n";
                return false;
            }
        }
        daftar_tim.push_back(t);
        cout << "  Tim \"" << t->getNama()
             << "\" [" << t->getTag() << "] berhasil didaftarkan!\n";
        return true;
    }
 
    void buatJadwal() {
        if ((int)daftar_tim.size() < 2) {
            cout << "  Minimal 2 tim untuk membuat jadwal!\n"; return;
        }
        jadwal.clear();
        int no = 1, n = daftar_tim.size();
        for (int i = 0; i < n; i++)
            for (int j = i+1; j < n; j++)
                jadwal.push_back(Pertandingan(no++, daftar_tim[i], daftar_tim[j]));
        cout << "  " << jadwal.size()
             << " pertandingan berhasil dijadwalkan!\n";
    }
 
    void tampilInfoTurnamen() {
        judul("INFO TURNAMEN MOBA");
        cout << "  Nama          : " << nama      << "\n";
        cout << "  Lokasi        : " << lokasi    << "\n";
        cout << "  Tanggal       : " << tanggal   << "\n";
        cout << "  Game          : " << game_moba << "\n";
        cout << "  Tim Terdaftar : " << daftar_tim.size() << " tim\n";
        cout << "  Pertandingan  : " << jadwal.size() << " match\n";
        hadiah->tampilHadiah();
    }
 
    // MODUL 4 - Runtime Polymorphism
    void tampilDaftarTim() {
        judul("DAFTAR TIM - " + game_moba);
        if (daftar_tim.empty()) { cout << "  Belum ada tim.\n"; return; }
        cout << "  " << left
             << setw(4)  << "No"
             << setw(7)  << "Tag"
             << setw(23) << "Nama Tim"
             << setw(16) << "Asal Kota"
             << "Tipe\n";
        garis('-', 55);
        for (int i = 0; i < (int)daftar_tim.size(); i++) {
            Peserta* p = daftar_tim[i];
            cout << "  " << setw(4) << (i+1);
            p->tampilInfo(true);
        }
        garis('-', 55);
        cout << "  Total: " << daftar_tim.size() << " tim\n";
    }
 
    void tampilDetailTim() {
        tampilDaftarTim();
        if (daftar_tim.empty()) return;
        cout << "  Pilih nomor tim: ";
        int no;
        while (!(cin >> no)) { cin.clear(); clearBuffer(); cout << "  Input angka: "; }
        clearBuffer();
        if (no < 1 || no > (int)daftar_tim.size()) {
            cout << "  Nomor tidak valid!\n"; return;
        }
        Peserta* p = daftar_tim[no-1];
        p->tampilInfo();
    }
 
    void kelolaAnggota() {
        tampilDaftarTim();
        if (daftar_tim.empty()) return;
        cout << "  Pilih nomor tim: ";
        int no;
        while (!(cin >> no)) { cin.clear(); clearBuffer(); cout << "  Input angka: "; }
        clearBuffer();
        if (no < 1 || no > (int)daftar_tim.size()) {
            cout << "  Nomor tidak valid!\n"; return;
        }
        Tim* tim = daftar_tim[no-1];
        garis('-', 55);
        cout << "  Tim: " << tim->getNama()
             << " [" << tim->getTag() << "] ("
             << tim->jumlahAnggota() << "/" << tim->getKuota() << " pemain)\n";
        garis('-', 55);
        cout << "  1. Tambah anggota\n";
        cout << "  2. Hapus anggota\n";
        cout << "  3. Lihat roster\n";
        cout << "  Pilihan: ";
        int sub;
        while (!(cin >> sub)) { cin.clear(); clearBuffer(); cout << "  Input angka: "; }
        clearBuffer();
 
        if (sub == 1) {
            cout << "  Nama pemain: ";
            string np; getline(cin, np);
            tim->tambahAnggota(np);
        } else if (sub == 2) {
            tim->cetakRoster();
            if (tim->getAnggota().empty()) return;
            cout << "  Nomor yang dihapus: ";
            int idx;
            while (!(cin >> idx)) { cin.clear(); clearBuffer(); cout << "  Input angka: "; }
            clearBuffer();
            tim->hapusAnggota(idx - 1);
        } else if (sub == 3) {
            tim->cetakRoster();
        }
    }
 
    void editTim() {
        tampilDaftarTim();
        if (daftar_tim.empty()) return;
        cout << "  Pilih nomor tim yang diedit: ";
        int no;
        while (!(cin >> no)) { cin.clear(); clearBuffer(); cout << "  Input angka: "; }
        clearBuffer();
        if (no < 1 || no > (int)daftar_tim.size()) {
            cout << "  Nomor tidak valid!\n"; return;
        }
        Tim* tim = daftar_tim[no-1];
        cout << "  Edit: " << tim->getNama() << "\n";
        cout << "  Nama baru (Enter = skip)     : ";
        string s; getline(cin, s);
        if (!s.empty()) tim->setNama(s);
        cout << "  Asal kota baru (Enter = skip): ";
        getline(cin, s);
        if (!s.empty()) tim->setAsalKota(s);
        cout << "  Tag baru (Enter = skip)      : ";
        getline(cin, s);
        if (!s.empty()) tim->setTag(s);
        cout << "  Data berhasil diperbarui!\n";
    }
 
    void hapusTim() {
        tampilDaftarTim();
        if (daftar_tim.empty()) return;
        cout << "  Pilih nomor tim yang dihapus: ";
        int no;
        while (!(cin >> no)) { cin.clear(); clearBuffer(); cout << "  Input angka: "; }
        clearBuffer();
        if (no < 1 || no > (int)daftar_tim.size()) {
            cout << "  Nomor tidak valid!\n"; return;
        }
        cout << "  Tim \"" << daftar_tim[no-1]->getNama() << "\" dihapus.\n";
 
        // hapus jadwal dulu agar pointer di Pertandingan tidak dangling
        jadwal.clear();
        cout << "  Jadwal dihapus, silakan buat jadwal ulang.\n";
 
        delete daftar_tim[no-1];
        daftar_tim.erase(daftar_tim.begin() + no - 1);
    }
 
    void tampilJadwal() {
        judul("JADWAL PERTANDINGAN - " + game_moba);
        if (jadwal.empty()) { cout << "  Jadwal belum dibuat.\n"; return; }
        for (auto& p : jadwal) p.tampilBaris();
        garis('-', 55);
        int selesai = 0;
        for (auto& p : jadwal) if (p.getSudahSelesai()) selesai++;
        cout << "  Selesai: " << selesai
             << "/" << jadwal.size() << " pertandingan\n";
    }
 
    void inputHasil() {
        tampilJadwal();
        if (jadwal.empty()) return;
        cout << "\n  Pilih nomor match: ";
        int no;
        while (!(cin >> no)) { cin.clear(); clearBuffer(); cout << "  Input angka: "; }
        clearBuffer();
        if (no < 1 || no > (int)jadwal.size()) {
            cout << "  Nomor tidak valid!\n"; return;
        }
        jadwal[no-1].inputSkor();
    }
 
    void tampilKlasemen() {
        if (daftar_tim.empty()) { cout << "  Belum ada tim.\n"; return; }
 
        vector<Tim*> sorted = daftar_tim;
        sort(sorted.begin(), sorted.end(), [](Tim* a, Tim* b) {
            if (a->getPoin() != b->getPoin()) return a->getPoin() > b->getPoin();
            return a->getMenang() > b->getMenang();
        });
 
        int n = sorted.size();
        judul("KLASEMEN - " + nama + " (" + game_moba + ")");
        cout << left
             << setw(5)  << "  No"
             << setw(7)  << "Tag"
             << setw(22) << "Nama Tim"
             << setw(7)  << "M"
             << setw(7)  << "K"
             << setw(7)  << "Poin"
             << "Status\n";
        garis('-', 55);
        for (int i = 0; i < n; i++) {
            cout << "  " << setw(3)  << (i+1)
                 << setw(7)  << sorted[i]->getTag()
                 << setw(22) << sorted[i]->getNama()
                 << setw(7)  << sorted[i]->getMenang()
                 << setw(7)  << sorted[i]->getKalah()
                 << setw(7)  << sorted[i]->getPoin()
                 << sorted[i]->getStatus() << "\n";
        }
        garis('=', 55);
        if (n >= 1) cout << "  JUARA 1 : " << sorted[0]->getNama()
                         << " => Rp " << hadiah->getHadiah(1) << "\n";
        if (n >= 2) cout << "  JUARA 2 : " << sorted[1]->getNama()
                         << " => Rp " << hadiah->getHadiah(2) << "\n";
        if (n >= 3) cout << "  JUARA 3 : " << sorted[2]->getNama()
                         << " => Rp " << hadiah->getHadiah(3) << "\n";
        garis('=', 55);
    }
 
    void resetSemuaStatistik() {
        char konfirm;
        cout << "  Yakin reset semua statistik? (y/n): ";
        cin >> konfirm; clearBuffer();
        if (konfirm == 'y' || konfirm == 'Y') {
            for (auto t : daftar_tim) t->resetStatistik();
            jadwal.clear();
            cout << "  Semua statistik dan jadwal direset!\n";
        }
    }
 
    string getGameMoba()  const { return game_moba; }
    string getNama()      const { return nama; }
    int    jumlahTim()    const { return daftar_tim.size(); }
    Tim*   ambilTim(int i)      { return daftar_tim[i]; }
 
    ~Turnamen() {
        for (auto t : daftar_tim) delete t;
    }
};
 
// ============================================================
//  FUNGSI INPUT TIM BARU (hanya MOBA)
// ============================================================
Tim* inputTimBaru(const string& game_moba) {
    string nama, asal, tag;
 
    cout << "  Nama Tim   : "; getline(cin, nama);
    while (nama.empty()) {
        cout << "  Nama tidak boleh kosong! Nama Tim: ";
        getline(cin, nama);
    }
    cout << "  Asal Kota  : "; getline(cin, asal);
    cout << "  Tag Tim    : "; getline(cin, tag);
 
    // Buat tim sesuai game turnamen, tambah atribut khusus
    if (game_moba == "Mobile Legends") {
        string sid;
        cout << "  Server ID  : "; getline(cin, sid);
        return new TimML(nama, asal, tag, sid);
